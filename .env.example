# Copy this file to .env.local and fill in your Supabase project values.
# Expo requires the EXPO_PUBLIC_ prefix for variables accessible in the bundle.

EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# USDA FoodData Central API — free key at https://fdc.nal.usda.gov/api-guide.html
EXPO_PUBLIC_USDA_API_KEY=your-key-here

# Spoonacular — barcode fallback (150 points/day free) — spoonacular.com/food-api
EXPO_PUBLIC_SPOONACULAR_API_KEY=your-key-here

# Anthropic — AI trend summaries in the Feed tab (Trends segment)
# WARNING: exposed in the app bundle — move to a Supabase Edge Function for production
EXPO_PUBLIC_ANTHROPIC_API_KEY=your-key-here

# ── Stripe (credit purchases) ─────────────────────────────────
# Publishable key is safe to expose in the bundle (used for Stripe.js on web only).
# Secret key and webhook secret must ONLY be set as Supabase Edge Function secrets:
#   supabase secrets set STRIPE_SECRET_KEY=sk_test_...
#   supabase secrets set STRIPE_WEBHOOK_SECRET=whsec_...
#   supabase secrets set APP_URL=https://thirty60track.onrender.com
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key-here
